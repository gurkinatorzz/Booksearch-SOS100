@model Booksearch.ViewModels.RoomBookingVM

@{
    ViewData["Title"] = "Boka grupprum";
    ViewData["BodyClass"] = "rooms-page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/rooms.css" />
}
<div class="bookingSection">

    <div class="bookingImageLeft">
        <img src="/images/studyroom.jpg" alt="Study room">
    </div>

    <div class="bookingFormBox">

        <h1>Boka ett grupprum</h1>

        <!-- STEG 1: välj datum och tid -->
        <form method="post" class="roomSearch">
        
            <div class="formGroup">
                <label>Datum</label>
                <input type="date" name="Date">
            </div>

            <div class="formGroup">
                <label>Starttid</label>
                <input type="time" name="StartTime">
            </div>

            <div class="formGroup">
                <label>Sluttid</label>
                <input type="time" name="EndTime">
            </div>

            <button class="roomSubmit">
                Visa tillgängliga rum
            </button>

        </form>

        <!-- STEG 2: visa rum -->
        <div class="availableRooms">

            <h2>Tillgängliga rum</h2>

            <div class="roomCard">
                <p><strong>Rum London</strong> – 4 personer</p>
                <span class="available">Ledigt</span>
                <button>Boka</button>
            </div>

            <div class="roomCard">
                <p><strong>Rum Rom</strong> – 6 personer</p>
                <span class="unavailable">Upptaget</span>
            </div>

            <div class="roomCard">
                <p><strong>Rum Paris</strong> – 8 personer</p>
                <span class="available">Ledigt</span>
                <button>Boka</button>
            </div>

        </div>

    </div>

    <div class="bookingImageRight">
        <img src="/images/library.jpg" alt="Library">
    </div>

</div>