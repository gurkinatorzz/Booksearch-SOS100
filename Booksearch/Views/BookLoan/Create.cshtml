<h1>Låna bok</h1>
<p>Bok: @ViewBag.BookTitle</p>



<form asp-action="Create" method="post">
    
    <input type="hidden" name="BookId" value="@ViewBag.BookId" />
    <input type="hidden" name="BookTitle" value="@ViewBag.BookTitle" />
    
    <button type="submit">Låna bok</button>
    
    <label>Lånedatum:</label>
    <input type="datetime-local" name="LoanDate" 
           value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
           readonly/>

    <br />

    <label>Återlämningsdatum:</label>
    <input type="datetime-local" name="DueDate" 
           value="@DateTime.Now.AddDays(14).ToString("yyyy-MM-ddTHH:mm")" />
</form>