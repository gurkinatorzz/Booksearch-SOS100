@{
    ViewData["Title"] = "Låna bok";
}
@section Styles 
{
    <link rel="stylesheet" href="~/css/BookLoan.css"/>
}

<section class="loanContainer">
    
    <h1 class="loanTitle">Låna bok</h1>

    <div class="formCard">
        <p class="bookTitle"><strong>Bok:</strong> @ViewBag.BookTitle</p>
        <p class="bookTitle">
            <strong>Låntagare:</strong> @User.Identity?.Name
        </p>

        <form asp-action="Create" method="post" class="loanForm">
            
            <input type="hidden" name="BookId" value="@ViewBag.BookId" />
            <input type="hidden" name="BookTitle" value="@ViewBag.BookTitle" />

            <div class="formGroup">
                <label>Lånedatum</label>
                <input type="datetime-local" name="LoanDate"
                       value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                       readonly />
            </div>

            <div class="formGroup">
                <label>Återlämningsdatum</label>
                <input type="datetime-local" name="DueDate"
                       value="@DateTime.Now.AddDays(14).ToString("yyyy-MM-ddTHH:mm")" />
            </div>

            <button type="submit" class="returnBtn">Låna bok</button>

        </form>
    </div>
</section>