@model Booksearch.Models.BookLoan

@section Styles 
{
    <link rel="stylesheet" href="~/css/BookLoan.css"/>
}

<section class="loanContainer">

    <h1 class="loanTitle">Ändra datum på återlämning</h1>

    <div class="formCard">

        <p class="bookTitle"><strong>Bok:</strong> @Model.BookTitle</p>
        <p class="bookTitle"><strong>Låntagare:</strong> @Model.BorrowerName</p>

        <form asp-action="Edit" method="post" class="loanForm">

            <input type="hidden" name="Id" value="@Model.Id" />
            <input type="hidden" name="BookId" value="@Model.BookId" />
            <input type="hidden" name="BookTitle" value="@Model.BookTitle" />
            <input type="hidden" name="BorrowerName" value="@Model.BorrowerName" />
            <input type="hidden" name="LoanDate" value="@Model.LoanDate.ToString("yyyy-MM-ddTHH:mm")" />

            <div class="formGroup">
                <label>Lånedatum</label>
                <input type="datetime-local"
                       value="@Model.LoanDate.ToString("yyyy-MM-ddTHH:mm")"
                       readonly />
            </div>

            <div class="formGroup">
                <label>Återlämningsdatum</label>
                <input type="datetime-local"
                       name="DueDate"
                       value="@Model.DueDate.ToString("yyyy-MM-ddTHH:mm")" />
            </div>

            <button type="submit" class="returnBtn">Uppdatera Återlämningsdatum</button>

        </form>
    </div>
</section>