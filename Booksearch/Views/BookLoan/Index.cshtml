@model List<Booksearch.Models.BookLoan>

@section Styles 
{
    <link rel="stylesheet" href="~/css/BookLoan.css"/>
}

<section class="loanContainer">

    <div class="pageHeader">
        <h1 class="loanTitle">Lånade böcker</h1>
        <p class="subtitle">Här hanterar du dina befintliga boklån.</p>
        
    </div>

    <div class="loanCard">

        <h2>Aktiva lån</h2>

        <table class="loanTable">
            <thead>
            <tr>
                <th>Bok</th>
                <th>Låntagare</th>
                <th>Lånedatum</th>
                <th>Återlämnas</th>
                <th></th>
            </tr>
            </thead>

            <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var loan in Model)
                {
                    <tr>
                        <td>@loan.BookTitle</td>
                        <td>@loan.BorrowerName</td>
                        <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                        @{
                            var now = DateTime.Now;
                            var timeLeft = loan.DueDate - now;
                        }

                        <td style="color:@(loan.DueDate < now ? "red" : (timeLeft.TotalHours <= 24 ? "orange" : "black"))">
                            @loan.DueDate.ToString("yyyy-MM-dd HH:mm")

                            @if (loan.DueDate < now)
                            {
                                <span> (Försenad!)</span>
                            }
                            else if (timeLeft.TotalHours <= 24)
                            {
                                <span>
                                    (kvar: @timeLeft.Hours h @timeLeft.Minutes min)
                                </span>
                            }
                        </td>
                        <td class="actions">

                            <a class="editBtn" asp-action="Edit" asp-route-id="@loan.Id">Ändra</a>

                            <form asp-action="Return" method="post">
                                <input type="hidden" name="id" value="@loan.Id"/>
                                <button type="submit" class="returnBtn">Återlämna</button>
                            </form>

                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="empty">Inga aktiva lån ännu.</td>
                </tr>
            }
            </tbody>
        </table>

    </div>
</section>