@model Booksearch.ViewModels.LoginVM

@{
    ViewData["Title"] = "Logga in";
    ViewData["BodyClass"] = "login-page";
}

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h1>Logga in</h1>
            <p></p>
        </div>
        
        <form asp-action="Login" asp-controller="Account" method="post" asp-route-returnUrl="@ViewBag.ReturnUrl" class="login-form">
            <div class="form-group">
                <label asp-for="Username" class="form-label">E-post</label>
                <input asp-for="Username" class="form-input" placeholder="Ange din e-postadress" />
            </div>
            
            <div class="form-group">
                <label asp-for="Password" class="form-label">Lösenord</label>
                <input type="password" asp-for="Password" class="form-input" placeholder="Ange ditt lösenord" />
            </div>
            
            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage?.ToString()))
            {
                <div class="error-message">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960">
                        <path d="M480-280q17 0 28.5-11.5T520-320q0-17-11.5-28.5T480-360q-17 0-28.5 11.5T440-320q0 17 11.5 28.5T480-280Zm-40-160h80v-240h-80v240Zm40 360q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                    </svg>
                    @ViewBag.ErrorMessage
                </div>
            }
            
            <button type="submit" class="login-button">
                Logga in
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960">
                    <path d="M647-440H160v-80h487L423-744l57-56 320 320-320 320-57-56 224-224Z"/>
                </svg>
            </button>
        </form>
        
    </div>
</div>

@section Styles {
<style>
.login-page {
    background-image: var(--color-bg);
}

.login-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 175px);
    padding: clamp(16px, 4vw, 20px);
}

.login-card {
    background: white;
    border-radius: clamp(16px, 2vw, 20px);
    padding: clamp(28px, 6vw, 40px) clamp(20px, 5vw, 40px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    max-width: 440px;
    width: 100%;
    border: 1px solid #e8ddd4;
}

.login-header {
    text-align: center;
    margin-bottom: 32px;
}

.login-header h1 {
    color: #2c1810;
    font-size: clamp(1.8rem, 4vw, 2.2rem);
    font-weight: 700;
    margin: 0 0 8px 0;
    text-decoration: underline;
    text-decoration-color: var(--color-theme2);
    text-decoration-thickness: 2px;
    text-underline-offset: 8px;
}

.login-header p {
    color: #6b5b54;
    font-size: clamp(0.9rem, 2.5vw, 1rem);
    margin: 0;
    font-weight: 400;
}

.login-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.form-label {
    color: #2c1810;
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
}

.form-input {
    padding: clamp(12px, 3vw, 14px) clamp(14px, 3.5vw, 16px);
    border: 2px solid #e8ddd4;
    border-radius: 12px;
    font-size: max(16px, 1rem);
    font-family: inherit;
    background: #fafafa;
    transition: all 0.2s ease;
    outline: none;
}

.form-input:focus {
    border-color: var(--color-theme2);
    background: white;
    box-shadow: 0 0 0 3px rgba(222, 171, 127, 0.1);
}

.form-input:hover {
    border-color: #d4c4b8;
}

.form-input::placeholder {
    color: #9b8b82;
}

.error-message {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #d32f2f;
    background: #ffebee;
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid #ffcdd2;
    font-size: 0.9rem;
    font-weight: 500;
}

.error-message svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
    flex-shrink: 0;
}

.login-button {
    background: linear-gradient(135deg, var(--color-theme), var(--color-theme2));
    color: #2c1810;
    border: none;
    padding: clamp(14px, 3.5vw, 16px) clamp(20px, 5vw, 24px);
    border-radius: 12px;
    font-size: clamp(1rem, 2.5vw, 1.1rem);
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(.68,-0.55,.27,1.55);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 8px;
    position: relative;
    overflow: hidden;
}

.login-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(222, 171, 127, 0.4);
}

.login-button:active {
    transform: translateY(0);
}

.login-button svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
    transition: transform 0.3s ease;
}

.login-button:hover svg {
    transform: translateX(4px);
}

.login-footer {
    text-align: center;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid #e8ddd4;
}

.login-footer p {
    color: #6b5b54;
    font-size: 0.95rem;
    margin: 0;
}

.register-link {
    color: var(--color-theme2);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    transition: text-decoration-color 0.3s ease;
}

.register-link:hover {
    text-decoration-color: var(--color-theme2);
}

/* Mobile responsiveness */
@@media (max-width: 650px) {
    .login-container {
        padding: 16px;
        min-height: calc(100vh - 150px);
    }
    
    .login-card {
        padding: 28px 20px;
        border-radius: 16px;
    }
    
    .login-header h1 {
        font-size: 1.8rem;
    }
    
    .login-header p {
        font-size: 0.9rem;
    }
    
    .form-input {
        padding: 12px 14px;
        font-size: 16px; /* Prevents zoom on iOS */
    }
    
    .login-button {
        padding: 14px 20px;
        font-size: 1rem;
    }
:}
</style>
}