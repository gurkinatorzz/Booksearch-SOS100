<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer>
    <div><h1>Hitta böcker. Upptäck nya världar.&trade;</h1></div>
    <div>
        <h2>Skapare</h2>
        <p>Axel Magnusson - Axma0007@student.hv.se</p>
        <p>Gustav Johansson - Gujo0020@student.hv.se</p>
        <p>Rayan Hadrous - Rayan@student.hv.se</p>
        <p>Ruqia Ali Roselle - Ruqia@student.hv.se</p>
        <p>William Berge - Wibe0005@student.hv.se</p>
    </div>
    <div>
        <h2>Snabblänkar</h2>
        <a asp-action="Index" asp-controller="BookLibrary"><p>Bibliotek</p></a>
        <a asp-action="LibraryAdmin" asp-controller="BookLibrary"><p>Administrera bibliotek</p></a>
        <a asp-action="Index" asp-controller="Home"><p>Boka grupprum</p></a>
        <a asp-action="Index" asp-controller="Home"><p id="loggaInP">Logga in</p></a>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>