</div>

<footer>
    <div><h1>Hitta böcker. Upptäck nya världar.&trade;</h1></div>
    <div>
        <h2>Skapare</h2>
        <p>Axel Magnusson - Axma0007@student.hv.se</p>
        <p>Gustav Johansson - Gujo0020@student.hv.se</p>
        <p>Rayan Hadrous - Raha0027@student.hv.se</p>
        <p>Roselle Ali - Roselle.ali@student.hv.se</p>
        <p>William Berge - Wibe0005@student.hv.se</p>
    </div>
    <div>
        <h2>Snabblänkar</h2>
        <a asp-action="Index" asp-controller="BookLibrary"><p id="fastLinks">Bibliotek</p></a>
        @*<a asp-action="LibraryAdmin" asp-controller="BookLibrary"><p id="fastLinks">Administrera bibliotek</p></a>*@
        <a asp-controller="BookLoan" asp-action="Index">
            <p id="fastLinks">Mina lån</p>
