@using Booksearch.Models
@inject Booksearch.Services.BookLoanApiService BookLoanApiService
@{
    var hasUrgentLoan = false; 
    var hasOverdueLoan = false;

    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var userLoans = await BookLoanApiService.GetUserLoans(User.Identity.Name!);
        var now = DateTime.Now;

        hasUrgentLoan = userLoans.Any(l => l.DueDate >= now && l.DueDate <= now.AddHours(24));
        hasOverdueLoan = userLoans.Any(l => l.DueDate < now);
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Booksearch</title>
    <script type="importmap"></script>
    
    @* bortkommenterad pga att de inte gick att ändra något...*@
    @*<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/> *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Booksearch.styles.css" asp-append-version="true"/>
    @RenderSection("Styles", required: false)
</head>
 <body class="@ViewData["BodyClass"]">
<header>

    <nav class="navbar">
        <div class="navbarTop">
            <div class="loggedInAs"><p>Inloggad som: <strong>@(User.Identity?.Name ?? "Gäst")</strong></p></div>
            
            @* inbox svg *@
            @*<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960">
                <path d="M160-160q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h640q33 0 56.5 23.5T880-720v480q0 33-23.5 56.5T800-160H160Zm320-280L160-640v400h640v-400L480-440Zm0-80 320-200H160l320 200ZM160-640v-80 480-400Z"/>
            </svg>*@

            <div class="profileWrap">
                <button class="profileBtn" onclick="toggleDropdown()">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960">
                        <path d="M234-276q51-39 114-61.5T480-360q69 0 132 22.5T726-276q35-41 54.5-93T800-480q0-133-93.5-226.5T480-800q-133 0-226.5 93.5T160-480q0 59 19.5 111t54.5 93Zm146.5-204.5Q340-521 340-580t40.5-99.5Q421-720 480-720t99.5 40.5Q620-639 620-580t-40.5 99.5Q539-440 480-440t-99.5-40.5ZM480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                    </svg>
                </button>
                <div class="profileDropdown" id="profileDropdown">
                    <div class="dropdownHeader">
                        <div class="dropdownName">@(User.Identity?.Name ?? "Gäst")</div>
                    </div>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="MyAccount" class="dropdownItem">Mitt konto</a>

                        <hr class="dropdownDivider"/>
                        <a asp-controller="Rooms" asp-action="MinaBokningar" class="dropdownItem">Mina bokningar</a>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Rooms" asp-action="AllaBokningar" class="dropdownItem">Se alla bokningar</a>
                            <a asp-controller="Admin" asp-action="Index" class="dropdownItem">Admin Dashboard</a>
                        }
                        @* WILLIAM: Ersätt href="#" med rätt länk *@
                        <a asp-controller="BookLoan" asp-action="Index" class="dropdownItem">Mina Lån</a>
                        <hr class="dropdownDivider"/>

                        @* AXEL: Ersätt href="#" med rätt logout-länk *@
                        <a asp-controller="Account" asp-action="Logout" class="dropdownItem dropdownLogout">Logga ut</a>
                    }
                    else
                    {
                        @* AXEL: Ersätt href="#" med rätt login-länk *@
                        <a asp-controller="Account" asp-action="Login" class="dropdownItem">Logga in</a>
                    }
                </div>
            </div>
        </div>
        <div class="navbarBottom">
            <a asp-area="" asp-controller="Home" asp-action="Index"><img class="navbarImg" src="~/images/booksearchLogo2.png" alt="Booksearch"/></a>

            <div class="navActions">
                <ul id="navbarList">
                    <li>
                        <a asp-area="" asp-controller="Home" asp-action="Index">Hem</a>
                    </li>
                    <li>
                        <a  asp-area="" asp-controller="BookLibrary" asp-action="Index">Bibliotek</a>
                    </li>
                    @*<li>
                        <a asp-area="" asp-controller="BookLibrary" asp-action="LibraryAdmin">ADMIN BIBLIOTEK</a>
                    </li>*@
                    <li id="navBooking">
                        <a asp-area="" asp-controller="Rooms" asp-action="BokaGrupprum">Bokning</a>
                    </li>
                    @*<li>
                        
                        <a asp-area="" asp-controller="BookLoan" asp-action="Index">Mina Lån</a> $1$lägg in korrekt länk#1#
                    </li>*@
                    <li class="loan-nav-item">
                        <a asp-area="" asp-controller="BookLoan" asp-action="Index" class="loan-link">
                            Mina Lån
                        </a>

                        @if (hasOverdueLoan)
                        {
                            <span class="loan-dot red-dot"></span>
                        }
                        else if (hasUrgentLoan)
                        {
                            <span class="loan-dot orange-dot"></span>
                        }
                    </li>
                    <li>
                        <a asp-controller="Reservation" asp-action="MyReservations">
                            Reservationer
                        </a>
                    </li>
                </ul>
                <button class="hamburgerButton">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960">
                        <path d="M120-240v-80h720v80H120Zm0-200v-80h720v80H120Zm0-200v-80h720v80H120Z"/>
                    </svg>
                </button>   
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
