<h1>Admin Dashboard</h1>
<p>Welcome to the admin panel.</p>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">User Management</h5>
                <p class="card-text">Add, edit, and remove users from the system.</p>
                <a asp-action="UserAdmin" class="btn btn-primary">Manage Users</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Library Management</h5>
                <p class="card-text">Manage books, authors, and categories.</p>
                <a asp-controller="BookLibrary" asp-action="LibraryAdmin" class="btn btn-primary">Library Admin</a>
            </div>
        </div>
    </div>
</div>

<hr>
<a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger">Log out</a>